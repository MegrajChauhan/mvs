; This is a comment
; Defining an entity is generally done as
; metadata: {           ; A metadata is expected at the start
;     count = 10,       ; The maximum number of entities defined in the file
; }
; ID: EID {
;    config: {
;       local_list = true|false,
;       ll_lim = 100,
;    }
;    properties: {
;       ....
;    }
;    setup: {
;       prop_1 = value,
;       prop_2 = value, ; Values can be integers or boolean. Strings or characters are not allowed. only decimal integers are allowed
;       prop_3 = true,
;       prop_4 = 100
;    }
;    args: { 
;       ; anything and everything inside the args block is taken as a single argument string. The entity is given the string and it should parse the string itself.
;       ; everything inside the block, including comments, is passed as is.     
;       arg1      
;       arg2=11
;       -arg3
;       arg4=a,b,c
;    }
; }
; If any other instance needs to copy the above
; ID2: [ID]
; Note that ID must start from 0 and incrementally grow. For eg, you cannot have 10 at the first
; local_list: {
;    0: len [ID2 IDN ...]  ; This describes the local list for every entity. Every ID provided must be valid and exist. This section is kept at the end of the file. 
;    1: len [ID IDX ...]
; }
; example:
metadata: {
   count = 2
}
0: 100 {
  config: {
     local_list = true,
  }
  args: {
     -f="hello.txt"
  }
  setup: {
    io = true, 
  }
  add_to_ll: {
     1 = 0
  }
}
1: [0]
