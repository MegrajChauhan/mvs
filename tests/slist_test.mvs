; This is a comment
; Defining an entity is generally done as
; metadata: {           ; A metadata is expected at the start
;     count = 10,       ; The maximum number of entities defined in the file
; }
; ID: EID {
;    config: {
;       local_list = true|false,
;       ll_lim = 100,
;    },
;    properties: {
;       ....
;    },
;    setup: {
;       prop_1 = value,
;       prop_2 = value, ; Values can be integers or boolean. Strings or characters are not allowed. only decimal integers are allowed
;       prop_3 = true,
;       prop_4 = 100
;    },
;    args: {
;       arg1\      ; each argument is separated by a '\'. If there are spaces, tabs, or even comments before '\', they are included as part of the argument
;                  ; The preceeding spaces and tabs are not included though. From the first character till '\' is considered to be part of the argument
;       arg2=11\
;       -arg3\
;       arg4=a,b,c\
;    },
;    add_to_ll: {
;       2 ; here, the entity of ID=2 is added to the local list at LID=0 automatically
;    }
; }
; If any other instance needs to copy the above
; ID2: [ID]
; Note that ID must start from 0 and incrementally grow. For eg, you cannot have 10 at the first
; Also, note that LID in add_to_ll must also grow incrementally
; example:
metadata: {
   count = 2
}
0: 100 {
  config: {
     local_list = true,
  },
  args: {
     -f="hello.txt"
  },
  setup: {
    io = true, 
  },
  add_to_ll: {
     1 = 0
  }
}
1: [0]
